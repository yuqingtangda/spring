<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.demo.mapper.UserMapper">
	<select id="selectUserList" parameterType="hashmap" resultType="com.example.demo.model.User">
		SELECT *
		FROM TBL_USER T
	</select>
	
	<select id="selectUser" parameterType="hashmap" resultType="com.example.demo.model.User">
		SELECT *
		FROM TBL_USER
		WHERE USERID = #{userId}
	</select>
	
	<insert id="insertUser" parameterType="hashmap">
		INSERT INTO TBL_USER(USERID, PWD, USERNAME)
		VALUES(#{userId}, #{hashPwd}, #{userName})
	</insert>
	
	<delete id="deleteUser" parameterType="hashmap">
		DELETE FROM TBL_USER
		WHERE USERID = #{userId}
	</delete>

</mapper>